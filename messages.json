{
  "_README": [
    "EDIT THIS FILE to customize every Discord message, then `git add . && git commit && git push` to apply.",
    "Colors are hex like '#6b7a3a'. Text in {curly braces} is a placeholder that gets filled in.",
    "Placeholders by message:",
    "  events.kill/teamkill/join/leave/objective/admin: (none needed) | events.server: {title}",
    "  leaderboard.title: {periodLabel} {sort}   leaderboard.line: {rank} {medal} {name} {value} {sort} {kills} {deaths} {kd} {captures} {headshots} {longest_kill_m} {kill_streak_best}",
    "  weaponLeaderboard.title: {periodLabel}     weaponLeaderboard.line: {rank} {medal} {weapon} {kills}",
    "Anything you leave out falls back to the built-in default."
  ],

  "events": {
    "kill":      { "title": "Kill Confirmed",            "color": "#7a8b3c" },
    "teamkill":  { "title": "Fratricide — Friendly Fire", "color": "#b5503f" },
    "join":      { "title": "Operator Connected",         "color": "#4b5320" },
    "leave":     { "title": "Operator Disconnected",      "color": "#5a5a4a" },
    "objective": { "title": "Objective Secured",          "color": "#c2b280" },
    "admin":     { "title": "Command Action",             "color": "#8b7d5a" },
    "server":    { "title": "Server Notice — {title}",    "color": "#b8a878" }
  },

  "leaderboard": {
    "title": "Top Operators — {periodLabel} · {sort}",
    "color": "#c2b280",
    "medals": [],
    "line": "`#{rank}`  **{name}**  —  {value} {sort}  ·  K/D {kd}",
    "empty": "_No combat data recorded for this period._",
    "footer": "TGZ Tactical Command"
  },

  "weaponLeaderboard": {
    "title": "Weapon Effectiveness — {periodLabel}",
    "color": "#8b7d5a",
    "line": "`#{rank}`  **{weapon}**  —  {kills} confirmed",
    "empty": "_No weapon data recorded._"
  },

  "periodLabels": { "all": "All-Time", "day": "Daily Report", "week": "Weekly Report", "month": "Monthly Report" }
}
