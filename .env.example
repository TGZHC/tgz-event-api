# ──────────────────────────────────────────────────────────────────
# TGZ Event API — environment configuration
# Copy this file to ".env" for local dev, or set these as Railway
# service variables in production. Never commit your real .env.
# ──────────────────────────────────────────────────────────────────

# --- Core ---
PORT=3000
NODE_ENV=production

# Shared secret SAT sends in its Authorization header.
# SAT may send "Bearer <token>" or just "<token>" — both are accepted.
# Generate a strong one, e.g.:  openssl rand -hex 32
API_TOKEN=changeme-generate-a-long-random-token

# --- Database ---
# EASIEST (Railway): set ONE variable to the database's connection URL. On
# Railway add a variable named DATABASE_URL with the value:  ${{ MySQL.MYSQL_URL }}
# (or ${{ MariaDB.MARIADB_URL }}). When set, the five DB_* vars below are ignored.
# The variable name MYSQL_URL is also accepted.
DATABASE_URL=

# FALLBACK: individual settings, used only if DATABASE_URL/MYSQL_URL is blank.
DB_HOST=localhost
DB_PORT=3306
DB_USER=tgz
DB_PASSWORD=changeme
DB_NAME=tgz_events
DB_CONNECTION_LIMIT=5

# --- Discord webhooks (one per category; leave blank to disable a category) ---
# Anything without a specific webhook falls back to DISCORD_WEBHOOK_DEFAULT.
DISCORD_WEBHOOK_DEFAULT=
DISCORD_WEBHOOK_KILLS=
DISCORD_WEBHOOK_JOINS=
DISCORD_WEBHOOK_OBJECTIVES=
DISCORD_WEBHOOK_ADMIN=
DISCORD_WEBHOOK_SERVER=

# Optional: ping a role on admin/server-health alerts, e.g. <@&123456789>
DISCORD_ALERT_MENTION=
